WILDMAGIC_PROVIDER=ollama
WILDMAGIC_MODEL=qwen3.5:9b

WILDMAGIC_DIALOGUE_PROVIDER=ollama
WILDMAGIC_DIALOGUE_MODEL=qwen3.5:9b

WILDMAGIC_TRADE_PROVIDER=ollama
WILDMAGIC_TRADE_MODEL=qwen3.5:9b

WILDMAGIC_TOWN_PROVIDER=ollama
WILDMAGIC_TOWN_MODEL=qwen3.5:9b-q4_K_M

# Shared Ollama defaults used by every Ollama-backed provider unless overridden.
WILDMAGIC_OLLAMA_NUM_CTX=16384
WILDMAGIC_OLLAMA_TIMEOUT=300

# Optional multi-server routing. Leave these unset to use OLLAMA_HOST or localhost:11434.
# Urgent calls are wild magic, dialogue, and trade. Background calls are town generation.
# WILDMAGIC_URGENT_OLLAMA_HOST=http://127.0.0.1:11434
# WILDMAGIC_BACKGROUND_OLLAMA_HOST=http://127.0.0.1:11435
# WILDMAGIC_BACKGROUND_OLLAMA_NUM_GPU=0

# More specific overrides also work:
# WILDMAGIC_WILD_OLLAMA_HOST=http://127.0.0.1:11434
# WILDMAGIC_DIALOGUE_OLLAMA_HOST=http://127.0.0.1:11434
# WILDMAGIC_TRADE_OLLAMA_HOST=http://127.0.0.1:11434
# WILDMAGIC_TOWN_OLLAMA_HOST=http://127.0.0.1:11435
